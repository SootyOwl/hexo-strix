# ---- Rust ----
target/
# scoped cargo target dirs (e.g. target-forcing/) — avoid clobbering the live self-play build in target/
target-*/
perf.data*

# superpowers SDD scratch (progress ledger etc.)
.superpowers/

# ---- Python ----
__pycache__/
*.py[cod]
*.egg-info/
.venv/
.venv-*/
.python-version
uv.toml          # machine-local uv overrides
# uv.lock IS tracked — do not ignore it

# ---- Training / research outputs ----
# `runs` (no trailing slash) matches a real dir OR a symlink (e.g. runs -> ../hexo/runs)
runs
# docs/ stays untracked (plans/specs live on disk only) EXCEPT explicitly
# whitelisted research notes (the paper trail). To commit a new note, add a
# negation line for it here.
docs/*
!docs/research
docs/research/*
!docs/research/2026-07-14-solver-zobrist-collision-and-wl4-guard.md
*.pt             # model checkpoints
*.bin
*.tfevents.*
benchmark.txt
trajectories.json

# ---- Datasets / local eval results ----
data/

# ---- Databases (play-server games, replay buffers) ----
*.sqlite
*.sqlite-wal
*.sqlite-shm
*.sqlite.lock
*.db

# ---- Tooling caches ----
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
.cache/
.rocprofv3/

# ---- Third-party repos co-located during development ----
# SealBot eval opponent: clone Ramora0/HexTicTacToe into sealbot/
sealbot/

# ---- Local environment / secrets (keep .env.example only) ----
.env
.envrc*

# ---- Editor / OS ----
.vscode/
*.code-workspace
.DS_Store

