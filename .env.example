# Copy to `.env` next to compose.yaml on the Oracle box and fill in.
# (Do NOT commit the real .env — it holds the admin token.)

# Absolute path to the trained checkpoint ON THE HOST (must be `chmod a+r`).
# The serving image is torch-free and loads a .safetensors — `just deploy <ckpt>`
# exports your .pt KEEPING ITS NAME (checkpoint_245100.pt ->
# checkpoint_245100.safetensors) and rsyncs it here; point this at that exact
# filename (the deploy recipe prints it). The default below is just a placeholder.
HEXO_CHECKPOINT_HOST=/home/ubuntu/hexo-serve/champion.safetensors

# /admin token — pick a long random string, e.g. `openssl rand -hex 24`.
HEXO_ADMIN_TOKEN=

# Optional overrides (safe defaults shown):
# HEXO_PORT=8080          # host port (bound to 127.0.0.1 in compose.yaml)
# HEXO_MCTS_SIMS=64       # bot strength vs latency (default when no difficulty picked)
# HEXO_MAX_MOVES=400      # draw declared after this many total placements
# HEXO_MODEL_LABEL=hexo   # stable stats label
# HEXO_URL_PREFIX=        # e.g. /hexo when behind a path-prefixed proxy
# Selectable strength levels: sims mapped onto casual,easy,standard,strong
# HEXO_DIFFICULTY_SIMS=0,64,128,512
# HEXO_DEFAULT_DIFFICULTY=standard    # casual | easy | standard | strong

# --- Cloudflare Tunnel (optional public exposure) ---
# Uncomment BOTH lines to run the cloudflared sidecar alongside hexo: the profile
# switch, and the tunnel token from the Zero Trust dashboard (Networks → Tunnels).
# Route the tunnel's public hostname to  http://hexo:8080  in that dashboard.
# COMPOSE_PROFILES=tunnel
# CF_TUNNEL_TOKEN=
